# WHV Compass API — copy to .env and fill in values

# --- LLM (required for live answers; omit to use mock mode) ---
# Get a free key at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Model (default: gemini-2.0-flash; gemini-1.5-flash-8b for lower cost)
GEMINI_MODEL=gemini-2.0-flash

# --- GCP / Firestore ---
GCLOUD_PROJECT=whv-compass-dev
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# --- Firestore emulator (local dev with `firebase emulators:start`) ---
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8081

# --- App ---
API_PORT=8080
WEB_ORIGIN=http://localhost:3000

# Kill-switch: set to "true" to disable LLM calls instantly (cost control)
# READ_ONLY=false

# Rate limiting (questions per session per hour)
# RATE_LIMIT_QUESTIONS_PER_HOUR=20

# RAG
# RAG_TOP_K=6

# Turnstile (Cloudflare; required in production)
# TURNSTILE_SECRET_KEY=
