# ─────────────────────────────────────────────────────────────────────────────
# WHV Compass — example environment.  Copy to `.env` and fill in.
# NEVER commit a real `.env`. All real secrets live in Secret Manager / CI secrets.
# ─────────────────────────────────────────────────────────────────────────────

# --- LLM (Google Gemini, free tier for MVP) -------------------------------------
# Get a key at https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# --- GCP / Firebase -------------------------------------------------------------
GCLOUD_PROJECT=whv-compass-dev
# Leave empty to use the local Firestore emulator (recommended for dev):
FIRESTORE_EMULATOR_HOST=127.0.0.1:8081
# In Cloud Run, auth uses the runtime service account — no key file needed.
# For local admin access only, point to a downloaded key (gitignored):
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# --- API wiring -----------------------------------------------------------------
API_PORT=8080
# Public base URL the web app calls (Cloud Run URL in prod):
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# --- Abuse protection (login-less) ---------------------------------------------
# Cloudflare Turnstile — https://developers.cloudflare.com/turnstile/
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
RATE_LIMIT_QUESTIONS_PER_HOUR=20

# --- Cost guardrails ------------------------------------------------------------
MAX_TOKENS_PER_ANSWER=1200
RAG_TOP_K=6
