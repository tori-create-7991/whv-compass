# WHV Compass Web — copy to .env.local and fill in values

# --- API proxy (Next.js /api/chat → this URL) ---
# In local dev: API runs on port 8080, web on 3000 — default works if both run locally
API_BASE_URL=http://localhost:8080

# --- Public env (exposed to the browser) ---
# Direct API base URL (for /sources/submit which calls the API directly)
# Leave empty in local dev to use relative paths
NEXT_PUBLIC_API_BASE_URL=
